<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&amp;family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "on-secondary-fixed": "#001a41",
                    "inverse-on-surface": "#f0f1f2",
                    "surface-container-low": "#f3f4f5",
                    "secondary-container": "#0070eb",
                    "background": "#f8f9fa",
                    "surface-dim": "#d9dadb",
                    "on-secondary": "#ffffff",
                    "on-error-container": "#93000a",
                    "tertiary-fixed-dim": "#c6c6c6",
                    "surface-tint": "#4f54b4",
                    "outline": "#757684",
                    "on-secondary-container": "#fefcff",
                    "on-primary": "#ffffff",
                    "surface-variant": "#e1e3e4",
                    "primary-container": "#4b4fb0",
                    "on-surface": "#191c1d",
                    "error": "#ba1a1a",
                    "on-secondary-fixed-variant": "#004493",
                    "inverse-surface": "#2e3132",
                    "on-tertiary-container": "#d3d3d3",
                    "surface-container-high": "#e7e8e9",
                    "surface": "#f8f9fa",
                    "on-tertiary-fixed-variant": "#454747",
                    "tertiary": "#424344",
                    "secondary": "#0058bc",
                    "surface-container-highest": "#e1e3e4",
                    "on-error": "#ffffff",
                    "outline-variant": "#c5c5d4",
                    "surface-container-lowest": "#ffffff",
                    "on-background": "#191c1d",
                    "on-primary-fixed-variant": "#373a9b",
                    "tertiary-container": "#595b5b",
                    "surface-container": "#edeeef",
                    "on-tertiary-fixed": "#1a1c1c",
                    "primary-fixed-dim": "#c0c1ff",
                    "inverse-primary": "#c0c1ff",
                    "on-primary-container": "#ceceff",
                    "tertiary-fixed": "#e2e2e2",
                    "secondary-fixed-dim": "#adc6ff",
                    "primary": "#333697",
                    "on-tertiary": "#ffffff",
                    "primary-fixed": "#e1e0ff",
                    "error-container": "#ffdad6",
                    "surface-bright": "#f8f9fa",
                    "secondary-fixed": "#d8e2ff",
                    "on-surface-variant": "#454652",
                    "on-primary-fixed": "#04006d"
            },
            "borderRadius": {
                    "DEFAULT": "0.25rem",
                    "lg": "0.5rem",
                    "xl": "0.75rem",
                    "full": "9999px"
            },
            "fontFamily": {
                    "headline": ["Inter"],
                    "body": ["Inter"],
                    "label": ["Inter"]
            }
          },
        },
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            display: inline-block;
            line-height: 1;
            text-transform: none;
            letter-spacing: normal;
            word-wrap: normal;
            white-space: nowrap;
            direction: ltr;
        }
        .intelligent-void-bg {
            background: radial-gradient(circle at 50% 50%, #f8f9fa 0%, #edeeef 100%);
        }
        .voice-wave {
            mask-image: linear-gradient(to right, transparent, black 20%, black 80%, transparent);
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background text-on-background font-body intelligent-void-bg min-h-screen flex flex-col overflow-hidden">
<!-- Top Navigation Anchor -->
<header class="bg-[#f8f9fa] dark:bg-[#191c1d] shadow-[0_4px_32px_0_rgba(51,54,151,0.06)] fixed top-0 w-full z-50">
<div class="flex justify-between items-center px-6 py-4 w-full">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-[#3F51B5] text-2xl" data-icon="bubble_chart">bubble_chart</span>
<h1 class="font-['Inter'] headline-md tracking-[-0.02em] text-lg font-bold text-[#191c1d]">Probability AI</h1>
</div>
<div class="flex items-center gap-6">
<span class="text-[#454652] font-medium hidden md:block">Real-time Voice Mode</span>
<div class="w-10 h-10 rounded-full bg-surface-container-highest flex items-center justify-center cursor-pointer hover:bg-[#e1e3e4] transition-colors duration-300">
<span class="material-symbols-outlined text-on-surface-variant" data-icon="more_vert">more_vert</span>
</div>
</div>
</div>
</header>
<!-- Main Content Canvas -->
<main class="flex-grow flex flex-col items-center justify-center px-6 pt-24 pb-32">
<!-- AI Identity & Status -->
<div class="text-center mb-12">
<div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/10 text-primary mb-4">
<span class="relative flex h-2 w-2">
<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
<span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
</span>
<span class="text-xs font-bold tracking-widest uppercase">Listening</span>
</div>
<h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-on-surface mb-2">Probability AI</h2>
<p class="text-on-surface-variant text-lg opacity-80">Connected via Secure Neural Link</p>
</div>
<!-- The Intelligent Void: Voice Visualizer -->
<div class="relative w-full max-w-4xl aspect-[21/9] flex items-center justify-center voice-wave">
<!-- Fluid Particles/Wave Simulation (Represented by elegant CSS layout) -->
<div class="flex items-end justify-center gap-1 md:gap-2 h-full w-full">
<div class="w-1.5 md:w-3 bg-primary-container/20 rounded-full h-1/4"></div>
<div class="w-1.5 md:w-3 bg-primary/40 rounded-full h-2/5"></div>
<div class="w-1.5 md:w-3 bg-primary/60 rounded-full h-3/5"></div>
<div class="w-1.5 md:w-3 bg-primary-container rounded-full h-4/5 shadow-[0_0_20px_rgba(51,54,151,0.3)]"></div>
<div class="w-1.5 md:w-3 bg-primary/80 rounded-full h-1/2"></div>
<div class="w-1.5 md:w-3 bg-primary/30 rounded-full h-1/3"></div>
<div class="w-1.5 md:w-3 bg-primary-container/40 rounded-full h-2/3"></div>
<div class="w-1.5 md:w-3 bg-primary rounded-full h-full shadow-[0_0_30px_rgba(51,54,151,0.4)]"></div>
<div class="w-1.5 md:w-3 bg-primary/40 rounded-full h-3/4"></div>
<div class="w-1.5 md:w-3 bg-primary/60 rounded-full h-2/5"></div>
<div class="w-1.5 md:w-3 bg-primary-container/20 rounded-full h-1/4"></div>
<div class="w-1.5 md:w-3 bg-primary/40 rounded-full h-1/2"></div>
<div class="w-1.5 md:w-3 bg-primary-container/30 rounded-full h-3/5"></div>
</div>
</div>
<!-- User Video Thumbnail (Absolute positioned within canvas) -->
<div class="fixed bottom-36 right-8 w-40 h-56 rounded-3xl overflow-hidden shadow-2xl bg-surface-container-highest border-4 border-surface-container-lowest transform transition-transform hover:scale-105">
<img class="w-full h-full object-cover grayscale-[20%]" data-alt="portrait of a young woman smiling softly in warm indoor lighting with a blurred bookshelf in the background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCimLdi8oiCKtC1hugo7efoSkxuM_ztzlDJ2YS6yyY8Pz5N1xIPdnsQ1VoIentbecEqAf25nLT_BxeovnL6k4o_m-3PIV-hcmv9GlhQ1RUNLmBTOeMFw37rSDfux3Of2_NpvkUp7iaLYulnqqHRBAx-u-OrPLpDyh8tMggZ8RnILnFadEuMCdz-h9pSWRPXiJqz2o_t9HEQKSShasCXqO027Lj66dYbrAWq6gvJZ5i1FlJT58Po97LNvGl6Y4jBUxt0GefNNFhUdjQp"/>
<div class="absolute bottom-3 left-3 flex items-center gap-1.5 px-2 py-0.5 rounded-lg bg-black/40 backdrop-blur-md">
<span class="material-symbols-outlined text-white text-xs" data-icon="videocam">videocam</span>
<span class="text-white text-[10px] font-bold tracking-tight">YOU</span>
</div>
</div>
</main>
<!-- Interactive Controls Bar -->
<div class="fixed bottom-8 left-1/2 -translate-x-1/2 w-full max-w-md px-6">
<div class="bg-surface-container-lowest/80 backdrop-blur-[24px] rounded-[2rem] p-4 flex items-center justify-between shadow-[0_8px_32px_0_rgba(51,54,151,0.08)] border border-outline-variant/10">
<!-- Mute Toggle -->
<button class="w-14 h-14 rounded-full bg-surface-container-low flex items-center justify-center text-on-surface-variant hover:bg-surface-container-highest transition-all duration-300 active:scale-90">
<span class="material-symbols-outlined text-2xl" data-icon="mic_off">mic_off</span>
</button>
<!-- End Call (Primary Action) -->
<button class="flex items-center gap-3 px-8 h-14 rounded-full bg-error text-on-error shadow-[0_8px_24px_rgba(186,26,26,0.3)] hover:brightness-110 transition-all duration-300 active:scale-95">
<span class="material-symbols-outlined font-variation-settings-'FILL' 1" data-icon="call_end" style="font-variation-settings: 'FILL' 1;">call_end</span>
<span class="font-bold tracking-tight">End Call</span>
</button>
<!-- Video Toggle -->
<button class="w-14 h-14 rounded-full bg-primary-container text-white flex items-center justify-center hover:brightness-110 shadow-[0_4px_16px_rgba(75,79,176,0.3)] transition-all duration-300 active:scale-90">
<span class="material-symbols-outlined text-2xl" data-icon="videocam" style="font-variation-settings: 'FILL' 1;">videocam</span>
</button>
</div>
</div>
<!-- Bottom Navigation Shell (Persistent) -->
<nav class="fixed bottom-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-3 bg-[#ffffffcc] backdrop-blur-[20px] md:hidden">
<div class="flex flex-col items-center justify-center text-[#454652] px-5 py-2 hover:text-[#3F51B5] transition-all duration-300">
<span class="material-symbols-outlined mb-1" data-icon="chat_bubble">chat_bubble</span>
<span class="font-['Inter'] label-md uppercase tracking-wider text-[10px]">Chat</span>
</div>
<div class="flex flex-col items-center justify-center bg-gradient-to-br from-[#333697] to-[#4b4fb0] text-white rounded-2xl px-5 py-2 transition-all duration-300">
<span class="material-symbols-outlined mb-1" data-icon="settings_voice" style="font-variation-settings: 'FILL' 1;">settings_voice</span>
<span class="font-['Inter'] label-md uppercase tracking-wider text-[10px]">Voice</span>
</div>
<div class="flex flex-col items-center justify-center text-[#454652] px-5 py-2 hover:text-[#3F51B5] transition-all duration-300">
<span class="material-symbols-outlined mb-1" data-icon="videocam">videocam</span>
<span class="font-['Inter'] label-md uppercase tracking-wider text-[10px]">Vision</span>
</div>
<div class="flex flex-col items-center justify-center text-[#454652] px-5 py-2 hover:text-[#3F51B5] transition-all duration-300">
<span class="material-symbols-outlined mb-1" data-icon="history">history</span>
<span class="font-['Inter'] label-md uppercase tracking-wider text-[10px]">History</span>
</div>
</nav>
</body></html>
